{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "liteskill-vr",
  "version": "0.1.4",
  "identifier": "com.liteskill.vr",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build && cargo build --release --bin liteskillvr-mcp --no-default-features --manifest-path src-tauri/Cargo.toml",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "liteskill-vr",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: https://asset.localhost; style-src 'self'; connect-src 'self' http://127.0.0.1"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "linux": {
      "deb": {
        "files": {
          "/usr/bin/liteskillvr-mcp": "target/release/liteskillvr-mcp"
        }
      },
      "rpm": {
        "files": {
          "/usr/bin/liteskillvr-mcp": "target/release/liteskillvr-mcp"
        }
      }
    }
  }
}
